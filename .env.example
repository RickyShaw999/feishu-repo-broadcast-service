# Local dry-run defaults. Generate non-public webhook tokens before exposing the service.
SERVICE_NAME=feishu-repo-broadcast-service
DATABASE_PATH=/data/service.db
DELIVERY_MODE=dry_run
WORKER_ENABLED=true
WORKER_INTERVAL_SECONDS=2
LEASE_TIMEOUT_SECONDS=300
MAX_DELIVERY_ATTEMPTS=5

# Provider webhook validation tokens.
CODEUP_SECRET_TOKEN=
GITLAB_SECRET_TOKEN=

# Live Feishu delivery is disabled unless DELIVERY_MODE=live and a webhook is supplied.
# Prefer Docker Compose secrets in production instead of direct env vars.
FEISHU_WEBHOOK_URL=
FEISHU_SIGNING_SECRET=

# Caddy production defaults. Use a real domain for automatic HTTPS.
PUBLIC_HOST=repo-broadcast.example.com
HTTP_PORT=80
HTTPS_PORT=443
